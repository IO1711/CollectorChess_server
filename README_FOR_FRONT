```json
{
  "id": "UUID",
  "pieceID": "UUID",
  "pieceName": "pawn",
  "pieceColor": "white",
  "from": { "row": 1, "column": 4 },
  "to": { "row": 3, "column": 4 },
  "capturedPieceID": null,
  "capturedPieceName": null,
  "promotionPieceName": null,
  "equippedSkillID": null,
  "skillID": null,
